---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Page not found | Ticker Line" description="The requested Ticker Line page could not be found." canonicalPath="/404">
  <main id="main" class="not-found shell">
    <a class="brand" href="/" aria-label="Ticker Line home">
      <svg class="brand-mark" viewBox="0 0 32 32" aria-hidden="true"><path d="M3 21.5 9 15l5 4 7-10 8 4.5" /></svg>
      <span>ticker-line</span>
    </a>
    <div>
      <p class="eyebrow">404</p>
      <h1>This line ends here.</h1>
      <p>The page does not exist, but the API and its documentation are still available.</p>
      <a class="button button-primary" href="/">Return home</a>
    </div>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro'

const description =
  'Embed sparklines of stock, crypto, indices and more in HTML, markdown, and anywhere else images work.'

const directUrl = '/v1/sparkline?ticker=AAPL&timeframe=1m'
const directAbsoluteUrl = `https://ticker-line.com${directUrl}`
const htmlExample = `<img
  src="${directAbsoluteUrl}"
  alt="AAPL price over one month"
  width="160"
  height="48"
/>`
const markdownExample = `![AAPL price over one month](${directAbsoluteUrl})`
const jsonExample = `{
  "ticker": "AAPL",
  "timeframe": "1m",
  "price": 314.98,
  "referencePrice": 296.34,
  "change": 18.64,
  "changePercent": 6.29,
  "direction": "up",
  "dataAsOf": "2026-07-10T00:00:00.000Z",
  "svg": "<svg ...>...</svg>"
}`

const samples = [
  { ticker: 'AAPL', name: 'Apple' },
  { ticker: 'BTC/USD', name: 'Bitcoin' },
  { ticker: 'SPY', name: 'S&P 500' },
  { ticker: 'NAS100/USD', name: 'Nasdaq 100' },
  { ticker: 'XAU/USD', name: 'Gold' },
  { ticker: 'USD/CAD', name: 'USD / CAD' },
]
const presets = samples.map(({ ticker }) => ({ label: ticker, ticker }))

const parameters = [
  ['ticker', 'required', '—', 'Use a supported London Strategic Edge symbol.'],
  ['timeframe', 'optional', '1m', '1d, 7d, 1m, 3m, 1y, or 5y.'],
  ['theme', 'optional', 'light', 'light or dark.'],
  ['fill', 'optional', 'false', 'Fill gains and losses to the chart reference line.'],
  ['format', 'optional', 'svg', 'svg for embeds; json adds quote metrics and semantic errors.'],
]

const errors = [
  ['400', 'INVALID_REQUEST'],
  ['404', 'TICKER_NOT_FOUND'],
  ['422', 'INSUFFICIENT_DATA'],
  ['429', 'RATE_LIMITED'],
  ['502', 'PROVIDER_ERROR'],
  ['503', 'SERVICE_UNAVAILABLE'],
]

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebAPI',
  name: 'Ticker Line',
  description,
  documentation: 'https://ticker-line.com/',
  provider: { '@type': 'Organization', name: 'Ticker Line' },
  termsOfService: 'https://ticker-line.com/#terms',
}
---

<BaseLayout title="Ticker Line — Market sparklines through a URL" description={description}>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <header class="site-header">
    <nav class="topbar shell" aria-label="Primary navigation">
      <a class="brand" href="/" aria-label="Ticker Line home">
        <svg class="brand-mark" viewBox="0 0 32 32" aria-hidden="true"><path d="M3 21.5 9 15l5 4 7-10 8 4.5" /></svg>
        <span class="brand-divider" aria-hidden="true"></span>
        <span>ticker-line</span>
      </a>
      <div class="top-links">
        <a class="external-link" href="https://github.com/Kahtaf/ticker-line" target="_blank" rel="noopener noreferrer">GitHub <span aria-hidden="true">↗</span></a>
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle site theme">
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 1.5v2M8 12.5v2M1.5 8h2M12.5 8h2M3.4 3.4l1.4 1.4M11.2 11.2l1.4 1.4M12.6 3.4l-1.4 1.4M4.8 11.2l-1.4 1.4"/><circle cx="8" cy="8" r="2.5"/></svg>
        </button>
      </div>
    </nav>
  </header>

  <main id="main" class="docs shell">
    <aside class="docs-nav" aria-label="Documentation sections">
      <p>Overview</p>
      <a href="#start">Getting started</a>
      <a href="#try">Try it</a>
      <a href="#usage">Usage</a>
      <p>Reference</p>
      <a href="#request">Request</a>
      <a href="#response">Response</a>
      <a href="#errors">Errors</a>
      <a href="#freshness">Freshness</a>
    </aside>

    <article class="docs-content">
      <section class="intro" id="start">
        <h1>Market sparklines through a URL</h1>
        <p>Embed sparklines of stock, crypto, indices and more in HTML, markdown, and anywhere else images work.</p>
        <div class="market-rail" role="group" aria-label="Example market charts" data-market-rail>
          {samples.map(({ ticker, name }) => (
            <button
              type="button"
              class="market-card"
              aria-label={`Use ${name}, ${ticker}`}
              aria-pressed="false"
              data-market-card
              data-ticker={ticker}
              data-market-state="loading"
            >
              <span class="market-card-heading">
                <span class="market-name">{name}</span>
                <span class="market-symbol">{ticker}</span>
              </span>
              <span class="market-price" data-market-price>—</span>
              <span class="market-change" data-market-change>—</span>
              <span class="market-performance" data-market-performance data-direction="flat">
                <span data-market-percent>—</span>
                <span class="market-direction" aria-hidden="true">–</span>
              </span>
              <span class="market-chart" data-market-chart aria-hidden="true">
                <svg viewBox="0 0 160 48"><path d="M4 30 24 27 44 31 64 22 84 25 104 17 124 20 144 12 156 14" /></svg>
              </span>
            </button>
          ))}
        </div>
        <div class="code-block compact-code">
          <code data-live-url>{directAbsoluteUrl}</code>
          <button type="button" data-copy={directAbsoluteUrl} data-copy-live-url>Copy</button>
        </div>
      </section>

      <section id="try" aria-labelledby="try-title">
        <h2 id="try-title">Try it yourself</h2>
        <p class="section-copy">Choose an example or enter a symbol. The ticker must be supported by <a href="https://londonstrategicedge.com/data/#overview">London Strategic Edge</a>.</p>

        <form class="request-builder" data-request-builder novalidate>
          <div class="preset-row" aria-label="Examples">
            <span>Examples</span>
            {presets.map(({ label, ticker }) => (
              <a href={`/v1/sparkline?ticker=${encodeURIComponent(ticker)}&timeframe=1m`} data-ticker-preset={ticker}>{label}</a>
            ))}
          </div>

          <div class="builder-fields">
            <label>
              <span>Ticker</span>
              <input name="ticker" value="AAPL" autocomplete="off" spellcheck="false" maxlength="32" aria-describedby="ticker-error" />
              <small class="field-error" id="ticker-error" data-ticker-error aria-live="polite"></small>
            </label>
            <label>
              <span>Timeframe</span>
              <select name="timeframe">
                <option value="1d">1 day</option>
                <option value="7d">7 days</option>
                <option value="1m" selected>1 month</option>
                <option value="3m">3 months</option>
                <option value="1y">1 year</option>
                <option value="5y">5 years</option>
              </select>
            </label>
            <label>
              <span>Theme</span>
              <select name="theme">
                <option value="light" selected>Light</option>
                <option value="dark">Dark</option>
              </select>
            </label>
            <label>
              <span>Fill</span>
              <select name="fill">
                <option value="false" selected>Off</option>
                <option value="true">On</option>
              </select>
            </label>
          </div>

          <div class="preview-frame" data-preview-state="ready">
            <img data-preview-image src={directUrl} width="160" height="48" alt="AAPL price over one month" />
            <span class="preview-skeleton" aria-hidden="true"></span>
            <p class="preview-error" data-preview-error role="alert">Preview unavailable. Try another symbol.</p>
          </div>

          <div class="generated-url">
            <a data-generated-url href={directAbsoluteUrl}>{directAbsoluteUrl}</a>
            <button type="button" data-copy-generated>Copy</button>
          </div>
        </form>
      </section>

      <section id="usage" aria-labelledby="usage-title">
        <h2 id="usage-title">Usage</h2>
        <p class="code-label">HTML</p>
        <div class="code-block">
          <pre tabindex="0"><code data-html-example>{htmlExample}</code></pre>
          <button type="button" data-copy={htmlExample} data-copy-html>Copy</button>
        </div>
        <p class="code-label">Markdown</p>
        <div class="code-block">
          <pre tabindex="0"><code data-markdown-example>{markdownExample}</code></pre>
          <button type="button" data-copy={markdownExample} data-copy-markdown>Copy</button>
        </div>
      </section>

      <section id="request" aria-labelledby="request-title">
        <h2 id="request-title">Request</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Name</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
              {parameters.map(([name, requirement, fallback, detail]) => (
                <tr><td><code>{name}</code><small>{requirement}</small></td><td><code>{fallback}</code></td><td>{name === 'ticker' ? <>Use a supported <a href="https://londonstrategicedge.com/data/#overview">London Strategic Edge</a> symbol.</> : name === 'timeframe' ? <><code>1d</code>, <code>7d</code>, <code>1m</code>, <code>3m</code>, <code>1y</code>, or <code>5y</code>.</> : name === 'theme' ? <><code>light</code> or <code>dark</code>.</> : name === 'format' ? <><code>svg</code> for embeds; <code>json</code> for quote data and semantic errors.</> : detail}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section id="response" aria-labelledby="response-title">
        <h2 id="response-title">Response</h2>
        <p class="section-copy">Set <code>format=json</code> to return quote data and the rendered SVG in JSON. Leaving the <code>format</code> option out returns an embeddable SVG.</p>
        <div class="code-block">
          <pre tabindex="0"><code data-json-example>{jsonExample}</code></pre>
        </div>
        <p class="section-copy"><code>price</code> is the latest close. Change values compare it with <code>referencePrice</code>; <code>changePercent</code> is expressed in percentage points.</p>
      </section>

      <section id="errors" aria-labelledby="errors-title">
        <h2 id="errors-title">Errors</h2>
        <p class="section-copy">SVG requests stay embeddable: failures return HTTP 200 with a gray fallback image and error details in headers. JSON requests use semantic status codes.</p>
        <div class="error-example">
          <img src="/v1/sparkline?ticker=THIS_SYMBOL_SHOULD_NOT_EXIST&timeframe=1m" width="160" height="48" loading="lazy" alt="Gray fallback sparkline for an unknown ticker" />
          <pre><code>X-Error-Code: TICKER_NOT_FOUND
X-Error-Status: 404</code></pre>
        </div>
        <div class="error-codes">
          {errors.map(([status, code]) => <div><span>{status}</span><code>{code}</code></div>)}
        </div>
      </section>

      <section id="freshness" aria-labelledby="freshness-title">
        <h2 id="freshness-title">Freshness</h2>
        <p>Cache duration depends on timeframe, asset type, and market session. Freshness ranges from 25 minutes for one-day charts to five days for five-year charts. Inspect <code>X-Data-As-Of</code> or JSON <code>dataAsOf</code> for the source timestamp.</p>
        <p>During a provider outage, a recent cached chart may be served within a bounded stale window. No real-time guarantee is implied.</p>
      </section>

      <section id="terms" aria-labelledby="terms-title">
        <h2 id="terms-title">Terms</h2>
        <p>Free to call without an API key. Cache responses and avoid needless polling. Fair use applies: requests are rate-limited per IP to protect the shared service. Charts may be delayed or contain errors and are not financial advice.</p>
      </section>
    </article>
  </main>

  <footer class="site-footer shell">
    <span class="footer-meta">
      <span>© 2026 Ticker Line</span>
      <a class="status-link" href="/status" data-service-status data-status="unknown" aria-label="Service status: checking">
        <span class="status-dot" aria-hidden="true"></span>
        <span>Status</span>
      </a>
    </span>
    <span class="footer-links">
      <span><a href="https://github.com/kahtaf/OpenCandle">OpenCandle</a> — Open source financial analyst.</span>
      <span>Made by <a href="https://kahtaf.com">Kahtaf</a>.</span>
    </span>
  </footer>

  <script>
    import '../scripts/request-builder'
  </script>
</BaseLayout>
